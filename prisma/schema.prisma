generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model profiles {
  id                                                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name                                              String?
  email                                                  String?
  phone                                                  String?
  specialty                                              String?
  status                                                 UserStatus               @default(active)
  created_at                                             DateTime                 @default(now())
  is_profile_completed                                   Boolean?                 @default(false)
  address                                                Json?
  auth_user_id                                           String                   @unique @default(dbgenerated("auth.uid()")) @db.Uuid
  tenant_id                                              String?                  @default(dbgenerated("auth.uid()")) @db.Uuid
  role                                                   ProfileRole?
  is_owner                                               Boolean                  @default(false)
  clinic_id                                              String?                  @db.Uuid
  reviews_approved                                       appointment_reviews[]    @relation("review_approver")
  reviews_as_doctor                                      appointment_reviews[]    @relation("review_doctor")
  appointments                                           appointments[]
  doctor_specialties                                     doctor_specialties[]
  encounters                                             encounters[]
  lab_orders                                             lab_orders[]
  medical_files                                          medical_files[]
  medical_records                                        medical_records[]
  patients                                               patients[]
  pharmacy_sales                                         pharmacy_sales[]
  prescription_dispenses                                 prescription_dispenses[]
  clinics                                                clinics?                 @relation(fields: [clinic_id], references: [id])
  clinics_tenant                                         clinics?                 @relation("profile_tenant", fields: [tenant_id], references: [id])
  stock_movements                                        stock_movements[]
  stock_transfers_stock_transfers_approved_byToprofiles  stock_transfers[]        @relation("stock_transfers_approved_byToprofiles")
  stock_transfers_stock_transfers_initiated_byToprofiles stock_transfers[]        @relation("stock_transfers_initiated_byToprofiles")
  user_permissions                                       user_permissions[]
  user_roles                                             user_roles[]
  user_settings                                          user_settings[]

  @@index([auth_user_id])
  @@index([tenant_id])
}

model patients {
  id                     String                   @id @default(uuid()) @db.Uuid
  clinic_id              String                   @db.Uuid
  branch_id              String?                  @db.Uuid
  first_name             String?
  last_name              String?
  gender                 Gender?
  date_of_birth          DateTime?                @db.Date
  phone                  String?
  email                  String?
  address                String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @default(now()) @updatedAt
  deleted_at             DateTime?
  profile_id             String?                  @db.Uuid
  appointment_reviews    appointment_reviews[]
  appointments           appointments[]
  encounters             encounters[]
  file_storage           file_storage[]
  insurance_claims       insurance_claims[]
  invoices               invoices[]
  lab_orders             lab_orders[]
  medical_files          medical_files[]
  medical_records        medical_records[]
  patient_insurances     patient_insurances[]
  branches               branches?                @relation(fields: [branch_id], references: [id])
  clinics                clinics                  @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  profiles               profiles?                @relation(fields: [profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pharmacy_sales         pharmacy_sales[]
  prescription_dispenses prescription_dispenses[]

  @@index([clinic_id])
}

model appointments {
  id               String               @id @default(uuid()) @db.Uuid
  clinic_id        String               @db.Uuid
  branch_id        String?              @db.Uuid
  patient_id       String               @db.Uuid
  doctor_id        String?              @db.Uuid
  appointment_date DateTime
  status           AppointmentStatus    @default(scheduled)
  notes            String?
  created_at       DateTime             @default(now())
  updated_at       DateTime             @default(now()) @updatedAt
  deleted_at       DateTime?
  review           appointment_reviews?
  branches         branches?            @relation(fields: [branch_id], references: [id])
  clinics          clinics              @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  profiles         profiles?            @relation(fields: [doctor_id], references: [id])
  patients         patients             @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  encounters       encounters[]

  @@index([appointment_date])
  @@index([clinic_id])
}

model payments {
  id             String        @id @default(uuid()) @db.Uuid
  clinic_id      String        @db.Uuid
  invoice_id     String        @db.Uuid
  amount         Decimal?      @db.Decimal(12, 2)
  payment_method String?
  status         PaymentStatus @default(pending)
  paid_at        DateTime?
  updated_at     DateTime      @default(now()) @updatedAt
  deleted_at     DateTime?
  invoices       invoices      @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([clinic_id])
}

model invoices {
  id               String             @id @default(uuid()) @db.Uuid
  clinic_id        String             @db.Uuid
  branch_id        String?            @db.Uuid
  patient_id       String?            @db.Uuid
  invoice_type     String?
  invoice_number   String?
  total_amount     Decimal?           @db.Decimal(12, 2)
  status           InvoiceStatus      @default(draft)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @default(now()) @updatedAt
  deleted_at       DateTime?
  insurance_claims insurance_claims[]
  invoice_items    invoice_items[]
  branches         branches?          @relation(fields: [branch_id], references: [id])
  clinics          clinics            @relation(fields: [clinic_id], references: [id])
  patients         patients?          @relation(fields: [patient_id], references: [id])
  payments         payments[]
  pharmacy_sales   pharmacy_sales[]

  @@index([branch_id])
}

model encounters {
  id               String             @id @default(uuid()) @db.Uuid
  clinic_id        String             @db.Uuid
  patient_id       String             @db.Uuid
  branch_id        String?            @db.Uuid
  doctor_id        String?            @db.Uuid
  encounter_type   String?
  diagnosis        String?
  encounter_date   DateTime           @default(now())
  appointment_id   String?            @db.Uuid
  notes            String?
  updated_at       DateTime           @default(now()) @updatedAt
  deleted_at       DateTime?
  appointments     appointments?      @relation(fields: [appointment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branches         branches?          @relation(fields: [branch_id], references: [id])
  clinics          clinics            @relation(fields: [clinic_id], references: [id])
  profiles         profiles?          @relation(fields: [doctor_id], references: [id])
  patients         patients           @relation(fields: [patient_id], references: [id])
  insurance_claims insurance_claims[]
  lab_orders       lab_orders[]
}

model lab_orders {
  id                    String        @id @default(uuid()) @db.Uuid
  clinic_id             String        @db.Uuid
  encounter_id          String?       @db.Uuid
  patient_id            String        @db.Uuid
  branch_id             String?       @db.Uuid
  doctor_id             String?       @db.Uuid
  test_name             String?
  external_lab_provider String?
  external_order_id     String?
  status                String        @default("ordered")
  created_at            DateTime      @default(now())
  updated_at            DateTime      @default(now()) @updatedAt
  deleted_at            DateTime?
  branches              branches?     @relation(fields: [branch_id], references: [id])
  clinics               clinics       @relation(fields: [clinic_id], references: [id])
  profiles              profiles?     @relation(fields: [doctor_id], references: [id])
  encounters            encounters?   @relation(fields: [encounter_id], references: [id])
  patients              patients      @relation(fields: [patient_id], references: [id])
  lab_results           lab_results[]
}

model lab_results {
  id              String     @id @default(uuid()) @db.Uuid
  clinic_id       String     @db.Uuid
  lab_order_id    String     @db.Uuid
  result_data     Json?
  result_file_url String?
  received_at     DateTime?
  updated_at      DateTime   @default(now()) @updatedAt
  deleted_at      DateTime?
  lab_orders      lab_orders @relation(fields: [lab_order_id], references: [id], onDelete: Cascade)

  @@index([clinic_id])
}

model prescription_dispenses {
  id                          String                        @id @default(uuid()) @db.Uuid
  clinic_id                   String                        @db.Uuid
  branch_id                   String?                       @db.Uuid
  medical_record_id           String?                       @db.Uuid
  patient_id                  String?                       @db.Uuid
  dispensed_by                String?                       @db.Uuid
  dispensed_at                DateTime                      @default(now())
  updated_at                  DateTime                      @default(now()) @updatedAt
  deleted_at                  DateTime?
  prescription_dispense_items prescription_dispense_items[]
  branches                    branches?                     @relation(fields: [branch_id], references: [id])
  clinics                     clinics                       @relation(fields: [clinic_id], references: [id])
  profiles                    profiles?                     @relation(fields: [dispensed_by], references: [id])
  medical_records             medical_records?              @relation(fields: [medical_record_id], references: [id])
  patients                    patients?                     @relation(fields: [patient_id], references: [id])
}

model roles {
  id                    String             @id @default(uuid()) @db.Uuid
  name                  String
  created_at            DateTime           @default(now())
  created_by            String?            @db.Uuid
  deleted_at            DateTime?
  description           String?
  is_active             Boolean            @default(true)
  is_system             Boolean            @default(false)
  tenant_id             String             @db.Uuid
  updated_at            DateTime           @default(now()) @updatedAt
  updated_by            String?            @db.Uuid
  role_group_roles      role_group_roles[]
  role_hierarchy_child  role_hierarchy[]   @relation("child_role")
  role_hierarchy_parent role_hierarchy[]   @relation("parent_role")
  role_permissions      role_permissions[]
  clinics               clinics            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_roles          tenant_roles[]
  user_roles            user_roles[]

  @@unique([tenant_id, name])
}

model permissions {
  id                    String                 @id @default(uuid()) @db.Uuid
  name                  String                 @unique
  category_id           String?                @db.Uuid
  created_at            DateTime               @default(now())
  created_by            String?                @db.Uuid
  deleted_at            DateTime?
  description           String?
  group_id              String?                @db.Uuid
  is_active             Boolean                @default(true)
  tenant_id             String?                @db.Uuid
  updated_at            DateTime               @default(now()) @updatedAt
  updated_by            String?                @db.Uuid
  permission_categories permission_categories? @relation(fields: [category_id], references: [id])
  permission_groups     permission_groups?     @relation(fields: [group_id], references: [id])
  role_permissions      role_permissions[]
  tenant_permissions    tenant_permissions[]
  user_permissions      user_permissions[]
}

model permission_categories {
  id          String        @id @default(uuid()) @db.Uuid
  tenant_id   String?       @db.Uuid
  name        String        @unique
  description String?
  is_active   Boolean       @default(true)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @default(now()) @updatedAt
  deleted_at  DateTime?
  created_by  String?       @db.Uuid
  updated_by  String?       @db.Uuid
  permissions permissions[]
}

model permission_groups {
  id          String        @id @default(uuid()) @db.Uuid
  tenant_id   String?       @db.Uuid
  name        String        @unique
  description String?
  is_active   Boolean       @default(true)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @default(now()) @updatedAt
  deleted_at  DateTime?
  created_by  String?       @db.Uuid
  updated_by  String?       @db.Uuid
  permissions permissions[]
}

model user_roles {
  id         String    @id @default(uuid()) @db.Uuid
  tenant_id  String    @db.Uuid
  profile_id String    @db.Uuid
  role_id    String    @db.Uuid
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  profiles   profiles  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  roles      roles     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  clinics    clinics   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, profile_id, role_id])
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  created_at    DateTime    @default(now())
  created_by    String?     @db.Uuid
  deleted_at    DateTime?
  id            String      @id @default(uuid()) @db.Uuid
  is_active     Boolean     @default(true)
  is_deny       Boolean     @default(false)
  tenant_id     String      @db.Uuid
  updated_at    DateTime    @default(now()) @updatedAt
  updated_by    String?     @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  clinics       clinics     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, role_id, permission_id])
}

model user_permissions {
  id            String      @id @default(uuid()) @db.Uuid
  tenant_id     String      @db.Uuid
  profile_id    String      @db.Uuid
  permission_id String      @db.Uuid
  is_deny       Boolean     @default(false)
  expires_at    DateTime?
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @default(now()) @updatedAt
  deleted_at    DateTime?
  created_by    String?     @db.Uuid
  updated_by    String?     @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  profiles      profiles    @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  clinics       clinics     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, profile_id, permission_id])
}

model tenant_permissions {
  id            String      @id @default(uuid()) @db.Uuid
  tenant_id     String      @db.Uuid
  permission_id String      @db.Uuid
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @default(now()) @updatedAt
  deleted_at    DateTime?
  created_by    String?     @db.Uuid
  updated_by    String?     @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  clinics       clinics     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, permission_id])
}

model tenant_roles {
  id         String    @id @default(uuid()) @db.Uuid
  tenant_id  String    @db.Uuid
  role_id    String    @db.Uuid
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  roles      roles     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  clinics    clinics   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, role_id])
}

model role_hierarchy {
  id             String    @id @default(uuid()) @db.Uuid
  tenant_id      String    @db.Uuid
  parent_role_id String    @db.Uuid
  child_role_id  String    @db.Uuid
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt
  deleted_at     DateTime?
  created_by     String?   @db.Uuid
  updated_by     String?   @db.Uuid
  child_role     roles     @relation("child_role", fields: [child_role_id], references: [id], onDelete: Cascade)
  parent_role    roles     @relation("parent_role", fields: [parent_role_id], references: [id], onDelete: Cascade)
  clinics        clinics   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, parent_role_id, child_role_id])
}

model role_groups {
  id          String             @id @default(uuid()) @db.Uuid
  tenant_id   String             @db.Uuid
  name        String
  description String?
  is_active   Boolean            @default(true)
  created_at  DateTime           @default(now())
  updated_at  DateTime           @default(now()) @updatedAt
  deleted_at  DateTime?
  created_by  String?            @db.Uuid
  updated_by  String?            @db.Uuid
  roles       role_group_roles[]
  clinics     clinics            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, name])
}

model role_group_roles {
  id            String      @id @default(uuid()) @db.Uuid
  tenant_id     String      @db.Uuid
  role_group_id String      @db.Uuid
  role_id       String      @db.Uuid
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @default(now()) @updatedAt
  deleted_at    DateTime?
  created_by    String?     @db.Uuid
  updated_by    String?     @db.Uuid
  role_group    role_groups @relation(fields: [role_group_id], references: [id], onDelete: Cascade)
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  clinics       clinics     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, role_group_id, role_id])
}

model audit_logs {
  id          String    @id @default(uuid()) @db.Uuid
  tenant_id   String    @db.Uuid
  action      String
  actor_id    String?   @db.Uuid
  actor_email String?
  entity_type String?
  entity_id   String?   @db.Uuid
  old_values  Json?
  new_values  Json?
  ip_address  String?
  user_agent  String?
  device      String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt
  deleted_at  DateTime?
  created_by  String?   @db.Uuid
  updated_by  String?   @db.Uuid
  clinics     clinics   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

