/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model file_storage {
  id            String    @id @db.Uuid
  clinic_id     String    @db.Uuid
  patient_id    String?   @db.Uuid
  related_table String?
  related_id    String?   @db.Uuid
  file_url      String?
  file_type     String?
  created_at    DateTime  @default(now())
  clinics       clinics   @relation(fields: [clinic_id], references: [id])
  patients      patients? @relation(fields: [patient_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model insurance_claims {
  id                 String              @id @db.Uuid
  clinic_id          String              @db.Uuid
  patient_id         String?             @db.Uuid
  encounter_id       String?             @db.Uuid
  insurance_id       String?             @db.Uuid
  invoice_id         String?             @db.Uuid
  claim_amount       Decimal?            @db.Decimal(12, 2)
  approved_amount    Decimal?            @db.Decimal(12, 2)
  status             ClaimStatus         @default(submitted)
  submitted_at       DateTime            @default(now())
  clinics            clinics             @relation(fields: [clinic_id], references: [id])
  encounters         encounters?         @relation(fields: [encounter_id], references: [id])
  patient_insurances patient_insurances? @relation(fields: [insurance_id], references: [id])
  invoices           invoices?           @relation(fields: [invoice_id], references: [id])
  patients           patients?           @relation(fields: [patient_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model insurance_providers {
  id                 String               @id @db.Uuid
  name               String
  contact_email      String?
  contact_phone      String?
  patient_insurances patient_insurances[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model invoice_items {
  id          String    @id @default(uuid()) @db.Uuid
  clinic_id   String    @db.Uuid
  invoice_id  String    @db.Uuid
  description String?
  quantity    Int?
  unit_price  Decimal?  @db.Decimal(12, 2)
  total_price Decimal?  @db.Decimal(12, 2)
  updated_at  DateTime  @default(now()) @updatedAt
  deleted_at  DateTime?
  invoices    invoices  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([clinic_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model medical_files {
