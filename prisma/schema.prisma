/// Global catalog of medical specialties, curated by the app owner and shared by
/// every clinic. Not tenant-scoped (mirrors subscription_plans).
model specialties {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String               @unique
  name_ar            String?
  description        String?
  is_active          Boolean              @default(true)
  display_order      Int                  @default(0)
  created_at         DateTime             @default(now())
  updated_at         DateTime             @default(now()) @updatedAt
  created_by         String?              @db.Uuid
  updated_by         String?              @db.Uuid
  doctor_specialties doctor_specialties[]

  @@index([is_active])
}

/// Junction linking a doctor profile to one or more catalog specialties.
model doctor_specialties {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id   String      @db.Uuid
  specialty_id String      @db.Uuid
  created_at   DateTime    @default(now())
  profiles     profiles    @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  specialties  specialties @relation(fields: [specialty_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, specialty_id])
  @@index([profile_id])
  @@index([specialty_id])
}

/// Patient rating for a completed appointment. Requires clinic-admin approval
/// (status: pending -> approved/rejected) before public display.
model appointment_reviews {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id String       @unique @db.Uuid
  clinic_id      String       @db.Uuid
  patient_id     String       @db.Uuid
  doctor_id      String?      @db.Uuid
  rating         Int          @db.SmallInt
  comment        String?
  status         String       @default("pending")
  approved_by    String?      @db.Uuid
  approved_at    DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @default(now()) @updatedAt
  appointments   appointments @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  approver       profiles?    @relation("review_approver", fields: [approved_by], references: [id])
  clinics        clinics      @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  doctor         profiles?    @relation("review_doctor", fields: [doctor_id], references: [id])
  patients       patients     @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@index([clinic_id, status])
  @@index([patient_id])
  @@index([status, created_at(sort: Desc)])
}

/// Typed catalog of every configurable setting key (Enterprise Global Settings
/// Module). Values live per scope: global_settings (platform, matched by key),
/// tenant_settings, user_settings. See prisma/migrations/08_settings_core.sql.
model setting_definitions {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String            @unique
  module          String
  category        String
  value_type      String
  default_value   Json
  validation      Json?
  allowed_scopes  String[]          @default(["platform", "tenant"])
  is_sensitive    Boolean           @default(false)
  is_public       Boolean           @default(false)
  description     String?
  display_order   Int               @default(0)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now()) @updatedAt
  deleted_at      DateTime?
  created_by      String?           @db.Uuid
  updated_by      String?           @db.Uuid
  tenant_settings tenant_settings[]
  user_settings   user_settings[]

  @@index([module, display_order])
}

/// Per-clinic setting values (tenant scope of the layered settings system).
model tenant_settings {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String              @db.Uuid
  definition_id   String              @db.Uuid
  value           Json
  vault_secret_id String?             @db.Uuid
  version         Int                 @default(1)
  is_active       Boolean             @default(true)
  created_at      DateTime            @default(now())
  updated_at      DateTime            @default(now()) @updatedAt
  deleted_at      DateTime?
  created_by      String?             @db.Uuid
  updated_by      String?             @db.Uuid
  definition      setting_definitions @relation(fields: [definition_id], references: [id], onDelete: Cascade)
  clinics         clinics             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, definition_id])
  @@index([tenant_id])
}

/// Per-profile preference values (user scope of the layered settings system).
model user_settings {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id    String              @db.Uuid
  tenant_id     String?             @db.Uuid
  definition_id String              @db.Uuid
  value         Json
  version       Int                 @default(1)
  is_active     Boolean             @default(true)
  created_at    DateTime            @default(now())
  updated_at    DateTime            @default(now()) @updatedAt
  deleted_at    DateTime?
  created_by    String?             @db.Uuid
  updated_by    String?             @db.Uuid
  definition    setting_definitions @relation(fields: [definition_id], references: [id], onDelete: Cascade)
  profiles      profiles            @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  clinics       clinics?            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, definition_id])
  @@index([tenant_id, profile_id])
}

/// Append-only settings change log (all scopes). Rollback re-writes an old
/// value as a NEW version — never destructive.
model settings_history {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope          String
  tenant_id      String?   @db.Uuid
  profile_id     String?   @db.Uuid
  definition_key String
  old_value      Json?
  new_value      Json?
  version        Int
  change_reason  String?
  changed_by     String?   @db.Uuid
  changed_at     DateTime  @default(now())
  clinics        clinics?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, definition_key, changed_at(sort: Desc)])
  @@index([scope, changed_at(sort: Desc)])
}

/// Lookup categories (gender, appointment types, payment methods, ...).
model lookup_categories {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String          @unique
  name                String
  name_ar             String?
  description         String?
  allow_tenant_values Boolean         @default(true)
  is_system           Boolean         @default(false)
  is_active           Boolean         @default(true)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @default(now()) @updatedAt
  deleted_at          DateTime?
  created_by          String?         @db.Uuid
  updated_by          String?         @db.Uuid
  values              lookup_values[]
}

/// Lookup values with tenant shadowing: tenant_id NULL = global default;
/// a tenant row with the same code shadows the global row for that tenant.
/// NOTE: uniqueness is enforced by partial unique indexes in SQL (09_lookups.sql)
/// which Prisma cannot express — repository code must find-then-write in a
/// transaction, never upsert.
model lookup_values {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id   String            @db.Uuid
  tenant_id     String?           @db.Uuid
  code          String
  label         String
  label_ar      String?
  metadata      Json?
  display_order Int               @default(0)
  is_active     Boolean           @default(true)
  created_at    DateTime          @default(now())
  updated_at    DateTime          @default(now()) @updatedAt
  deleted_at    DateTime?
  created_by    String?           @db.Uuid
  updated_by    String?           @db.Uuid
  category      lookup_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)
  clinics       clinics?          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([category_id, tenant_id, display_order])
  @@index([tenant_id])
}

/// Platform-owned feature flag catalog. Evaluation chain: kill_switch >
/// tenant override > plan entitlement (subscription_features) > default_enabled.
model feature_flags {
  id              String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String                     @unique
  name            String
  name_ar         String?
  description     String?
  default_enabled Boolean                    @default(false)
  kill_switch     Boolean                    @default(false)
  environments    String[]                   @default(["production", "development"])
  is_beta         Boolean                    @default(false)
  is_active       Boolean                    @default(true)
  created_at      DateTime                   @default(now())
  updated_at      DateTime                   @default(now()) @updatedAt
  deleted_at      DateTime?
  created_by      String?                    @db.Uuid
  updated_by      String?                    @db.Uuid
  overrides       tenant_feature_overrides[]
}

/// App-owner-granted per-tenant feature exceptions (optionally expiring).
model tenant_feature_overrides {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String        @db.Uuid
  feature_key String
  is_enabled  Boolean
  reason      String?
  expires_at  DateTime?
  is_active   Boolean       @default(true)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @default(now()) @updatedAt
  deleted_at  DateTime?
  created_by  String?       @db.Uuid
  updated_by  String?       @db.Uuid
  feature     feature_flags @relation(fields: [feature_key], references: [key], onDelete: Cascade)
  clinics     clinics       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, feature_key])
  @@index([tenant_id])
}

/// Configurable document numbering. One row per (tenant, type, period); the
/// row is both counter and format config. Numbers are claimed atomically via
/// public.claim_document_number() (11_document_sequences.sql).
model document_sequences {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  document_type  String
  prefix         String    @default("")
  padding        Int       @default(5)
  reset_period   String    @default("never")
  period_key     String    @default("")
  include_period Boolean   @default(true)
  current_value  BigInt    @default(0)
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt
  deleted_at     DateTime?
  created_by     String?   @db.Uuid
  updated_by     String?   @db.Uuid
  clinics        clinics   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, document_type, period_key])
  @@index([tenant_id, document_type])
}

/// Notification templates: tenant_id NULL = global default; fallback chain
/// tenant+locale > tenant+en > global+locale > global+en.
/// Uniqueness enforced by partial unique indexes in SQL (12_notifications.sql).
model notification_templates {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String?   @db.Uuid
  channel      String
  template_key String
  locale       String    @default("en")
  subject      String?
  body         String
  variables    Json?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt
  deleted_at   DateTime?
  created_by   String?   @db.Uuid
  updated_by   String?   @db.Uuid
  clinics      clinics?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, template_key])
}

/// Per-tenant notification delivery config. config holds NON-secret fields
/// only; secret_ref is a Supabase Vault secret UUID — never the secret itself.
model notification_channels {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String    @db.Uuid
  channel_type     String
  config           Json      @default("{}")
  secret_ref       String?   @db.Uuid
  is_enabled       Boolean   @default(false)
  is_verified      Boolean   @default(false)
  last_verified_at DateTime?
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt
  deleted_at       DateTime?
  created_by       String?   @db.Uuid
  updated_by       String?   @db.Uuid
  clinics          clinics   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, channel_type])
  @@index([tenant_id])
}

/// In-app notification inbox — one row per recipient (display fields are
/// denormalized so the Realtime payload is self-sufficient). A single send
/// fans out to N rows sharing one group_id. See 13_in_app_notifications.sql.
/// FKs (tenant_id -> clinics, sender/recipient -> profiles) live in SQL; they
/// are intentionally not modeled as Prisma relations to keep this row
/// self-contained — the server actions query by scalar recipient_id/tenant_id.
model notifications {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String?   @db.Uuid
  group_id       String    @db.Uuid
  sender_id      String    @db.Uuid
  sender_role    String
  sender_name    String?
  recipient_id   String    @db.Uuid
  recipient_role String
  title          String
  body           String
  category       String?
  priority       String    @default("normal")
  deep_link      String?
  status         String    @default("unread")
  delivered_at   DateTime?
  read_at        DateTime?
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt
  deleted_at     DateTime?
  created_by     String?   @db.Uuid
  updated_by     String?   @db.Uuid

  @@unique([group_id, recipient_id])
  @@index([recipient_id, status])
  @@index([tenant_id])
  @@index([group_id])
}

